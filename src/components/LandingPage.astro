---
// LandingPage.astro - Main landing page component
import ZineCard from "./ZineCard.astro";
import type { Zine } from "../types";
import { parseCSVFile } from "../lib/csv";
import { downloadZinesFromDrive } from "../lib/import";
import rudiLogo from "../assets/rudi-logo.png";
import rudiTitle from "../assets/rudi-title.png";

// Download zines from Google Drive at build time
await downloadZinesFromDrive();

// Get all zine images from the zines subdirectory
const allZineImages = import.meta.glob(
  "../assets/zines/*.{png,jpg,jpeg,webp}",
  { eager: true },
);

// Load zine data from CSV (now locally available after download)
const csvData = await parseCSVFile("zines.csv");

// Map CSV data to Zine type and resolve images from glob
const zines: Zine[] = csvData.map((row) => {
  let matchedImage;

  matchedImage = Object.values(allZineImages).find((img) =>
    (img as any).default?.src?.includes(row.imageFilename),
  );

  return {
    title: row.title,
    imageFilename: row.imageFilename,
    author: row.author || undefined,
    description: row.description || undefined,
    uploadDate: row.uploadDate || undefined,
    image: matchedImage ? (matchedImage as any).default : undefined,
  };
});
---

<!-- Header Section - Full width, centered -->
<header class="py-8 w-full flex justify-center">
  <!-- Logo and Title -->
  <div class="flex items-center gap-2">
    <img src={rudiLogo.src} alt="Rudi Press Logo" class="h-16" />
    <img src={rudiTitle.src} alt="Rudi Press" class="h-16" />
  </div>
</header>

<div class="container mx-auto px-4">
  <!-- Hero Section -->
  <section class="mt-8 py-8">
    <div id="zines" class="flex flex-wrap justify-center gap-6 px-4">
      {zines.map((zine) => <ZineCard zine={zine} />)}
    </div>
  </section>
</div>

<div class="container mx-auto px-4">
  <!-- About Section -->
  <section class="mt-8 py-8 px-4 max-w-full md:max-w-2/3 mx-auto text-center">
    Rudi Press is an independent publication based out of unnceded territories
    of the xʷməθkʷəy̓əm (Musqueam), Sḵwx̱wú7mesh (Squamish), and səlilwətaɬ
    (Tsleil-Waututh) Nations. The people of these nations have stewarded the
    land since untold times, and we are an uninvited guest.
  </section>
</div>
